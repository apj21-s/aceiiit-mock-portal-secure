PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/ugee_mock_portal
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
ADMIN_EMAILS=admin1@example.com,admin2@example.com
REQUEST_TIMEOUT_MS=15000
SERVER_REQUEST_TIMEOUT_MS=15000
KEEP_ALIVE_TIMEOUT_MS=65000
HEADERS_TIMEOUT_MS=66000

# Email OTP provider (Resend)
RESEND_API_KEY=replace-with-resend-api-key

# Google Sheets paid verification (API key + public sheet)
PAID_SHEETS_API_KEY=replace-with-google-api-key
PAID_SHEETS_SHEET_ID=replace-with-sheet-id
PAID_SHEETS_RANGE=Verified!A:A
PAID_SHEETS_SYNC_INTERVAL_SECONDS=300
PAID_SHEETS_STARTUP_DELAY_MS=10000

# CORS (only needed if serving frontend separately)
CORS_ORIGIN=

# Mongo tuning
MONGO_MAX_POOL_SIZE=25
MONGO_MIN_POOL_SIZE=3
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=15000
MONGO_CONNECT_TIMEOUT_MS=5000
DB_RETRY_DELAY_MS=5000

# Attempt queue smoothing
ATTEMPT_QUEUE_CONCURRENCY=8
ATTEMPT_QUEUE_MAX_SIZE=180
ATTEMPT_QUEUE_MAX_WAIT_MS=20000
UPLOAD_REQUEST_TIMEOUT_MS=45000

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
# Or set a single variable:
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
